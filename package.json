{
  "name": "astro-game",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:client": "npm --workspace @astro-game/client run dev",
    "dev:server": "npm --workspace @astro-game/server run dev",
    "smoke:ws": "node scripts/smoke-ws.mjs",
    "check": "npm run check --workspaces",
    "build": "npm run build --workspaces"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  }
}
